<Window x:Class="LivewireBrowser.App.Views.OutputDeviceWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:LivewireBrowser.App.ViewModels"
        Title="{DynamicResource Str_SelectOutputDevice}" MinWidth="320" MaxWidth="900" SizeToContent="WidthAndHeight"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize" Background="{StaticResource WindowBgBrush}">
    <StackPanel Margin="14">
        <TextBlock Text="{DynamicResource Str_SelectOutputDevice}" FontSize="13" FontWeight="Bold" Margin="0,0,0,10" />

        <!-- SizeToContent="WidthAndHeight" on the Window sizes the dialog to the longest
             device name automatically — HorizontalScrollBarVisibility="Disabled" is just a
             safety net for the rare name long enough to hit MaxWidth. -->
        <ListBox x:Name="DeviceListBox" ItemsSource="{Binding}" DisplayMemberPath="Name"
                 MaxHeight="240" BorderThickness="0.5" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
            <ListBox.ItemContainerStyle>
                <Style TargetType="ListBoxItem">
                    <Setter Property="Padding" Value="7,6" />
                </Style>
            </ListBox.ItemContainerStyle>
        </ListBox>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="{DynamicResource Str_Select}" Width="80" Margin="0,0,8,0" Click="OnSelectClick" />
            <Button Content="{DynamicResource Str_Cancel}" Width="80" Click="OnCancelClick" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
