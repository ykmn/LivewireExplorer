<Window x:Class="LivewireBrowser.App.Views.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{DynamicResource Str_SettingsTitle}" Width="460" SizeToContent="Height" WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" Background="{StaticResource WindowBgBrush}">
    <StackPanel Margin="16">
        <TextBlock Text="{DynamicResource Str_NetworkInterface}" />
        <StackPanel Orientation="Horizontal" Margin="0,4,0,12">
            <ComboBox x:Name="InterfaceComboBox" Width="320" DisplayMemberPath="DisplayName" />
            <Button Content="{DynamicResource Str_Refresh}" Width="80" Margin="8,0,0,0" Click="OnRefreshInterfacesClick" />
        </StackPanel>

        <TextBlock Text="{DynamicResource Str_DiscoveryModeLabel}" />
        <ComboBox x:Name="DiscoveryModeComboBox" Margin="0,4,0,12" Width="320" HorizontalAlignment="Left"
                  DisplayMemberPath="Label" />

        <TextBlock Text="{DynamicResource Str_RescanPeriodLabel}" />
        <TextBox x:Name="PeriodTextBox" Margin="0,4,0,12" Width="100" HorizontalAlignment="Left" />

        <TextBlock Text="{DynamicResource Str_LanguageLabel}" />
        <ComboBox x:Name="LanguageComboBox" Margin="0,4,0,12" Width="160" HorizontalAlignment="Left"
                  DisplayMemberPath="Label" />

        <TextBlock Text="{DynamicResource Str_CachePathLabel}" />
        <TextBlock x:Name="CachePathText" Margin="0,4,0,12" TextWrapping="Wrap" />

        <Button Content="{DynamicResource Str_ClearCache}" Width="120" HorizontalAlignment="Left" Margin="0,0,0,12"
                Click="OnClearCacheClick" />

        <TextBlock Text="{DynamicResource Str_LogFolderLabel}" />
        <TextBlock x:Name="LogPathText" Margin="0,4,0,4" TextWrapping="Wrap" />
        <Button Content="{DynamicResource Str_OpenLogsFolder}" Width="160" HorizontalAlignment="Left" Margin="0,0,0,12"
                Click="OnOpenLogsClick" />

        <TextBlock Text="{DynamicResource Str_LogLevelLabel}" />
        <ComboBox x:Name="LogLevelComboBox" Margin="0,4,0,12" Width="160" HorizontalAlignment="Left" />

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="{DynamicResource Str_Save}" Width="80" Margin="0,0,8,0" Click="OnSaveClick" />
            <Button Content="{DynamicResource Str_Cancel}" Width="80" Click="OnCancelClick" IsCancel="True" />
        </StackPanel>
    </StackPanel>
</Window>
